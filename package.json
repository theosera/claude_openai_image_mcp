{
  "name": "claude-openai-image-mcp",
  "version": "0.1.0",
  "description": "Local MCP server that generates images via the OpenAI Images API (gpt-image-2) and returns them as MCP ImageContent. Server-side API key only.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": "./dist/index.js",
    "./provider": "./dist/providerContract.js"
  },
  "bin": {
    "claude-openai-image-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:ox": "oxlint src tests",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "dotenv": "^17.4.2",
    "openai": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
