# claude_openai_image_mcp — environment template.
# Copy to `.env` and fill values locally. NEVER commit `.env` or real secrets.

# OpenAI API key (server-side only). Create at https://platform.openai.com/api-keys.
# Required only when IMAGE_MCP_PROVIDER=openai. Leave empty for the mock provider.
OPENAI_API_KEY=

# Which image provider to use: "mock" (no network, no billing), "openai", or
# "plugin" (experimental detachable lane; see README "Pluggable provider lane").
IMAGE_MCP_PROVIDER=mock

# Module specifier or path of an external provider plugin. Used ONLY when
# IMAGE_MCP_PROVIDER=plugin (both must be set; remove both to detach the lane).
# The module runs IN-PROCESS with full server privileges — only install code
# you wrote or audited.
IMAGE_MCP_PROVIDER_MODULE=

# Effective model (server chooses; clients never pass a model name).
OPENAI_IMAGE_MODEL=gpt-image-2

# Bounds (provisional — tuned via E2E; see README).
IMAGE_MCP_MAX_PROMPT_CHARS=2000
IMAGE_MCP_TIMEOUT_MS=60000
IMAGE_MCP_MAX_RETRIES=0
IMAGE_MCP_MAX_CONCURRENCY=1
# Max DECODED image bytes accepted from any provider (untrusted-output bound).
IMAGE_MCP_MAX_IMAGE_BYTES=15728640

# Allowlists (comma-separated). Requests outside these are rejected before any API call.
IMAGE_MCP_ALLOWED_SIZES=1024x1024,1536x1024,1024x1536
IMAGE_MCP_ALLOWED_QUALITIES=low,medium
IMAGE_MCP_ALLOWED_FORMATS=png,webp,jpeg

# Defaults applied when the client omits the field (must be within the allowlists).
IMAGE_MCP_DEFAULT_SIZE=1024x1024
IMAGE_MCP_DEFAULT_QUALITY=low
IMAGE_MCP_DEFAULT_FORMAT=png
