{
  "name": "codex-plugin-cc",
  "version": "0.1.0",
  "description": "Detachable image provider plugin for claude-openai-image-mcp: generates images through the OpenAI Codex CLI (ChatGPT subscription lane), no API key.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "peerDependencies": {
    "claude-openai-image-mcp": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "claude-openai-image-mcp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "claude-openai-image-mcp": "file:../..",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
