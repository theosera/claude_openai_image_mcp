# codex-plugin-cc — environment template. Copy to `.env` for local runs.
# This lane uses your ChatGPT subscription via the Codex CLI. Do NOT set
# OPENAI_API_KEY here — the plugin strips it from codex's environment on purpose
# (the subscription lane must never fall back to per-image API billing).

# Executable to run (must be logged in: `codex login`). Default: codex
CODEX_PLUGIN_COMMAND=codex

# Base args before the prompt (JSON array or space-separated). `codex exec` is
# the non-interactive entrypoint; adjust for your codex version if needed.
# Default: ["exec","--full-auto"]
CODEX_PLUGIN_ARGS=["exec","--full-auto"]

# Directory for per-request scratch subdirs. Default: OS temp dir.
CODEX_PLUGIN_TMPDIR=

# Advisory label reported as the result model. The subscription lane's real
# model is backend-decided (currently gpt-image-2) and NOT client-pinnable.
CODEX_PLUGIN_MODEL_LABEL=

# Run `codex login status` before the first generation (1/true to enable).
# Default off (a missing session is still detected from the generation attempt).
CODEX_PLUGIN_PREFLIGHT_LOGIN=
