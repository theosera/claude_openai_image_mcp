# codex-plugin-cc — environment template. Copy to `.env` for local runs.
# This lane uses your ChatGPT subscription via the Codex CLI. Do NOT set
# OPENAI_API_KEY or CODEX_API_KEY here — the plugin strips both from codex's
# environment on purpose (the subscription lane must never fall back to
# per-image API billing).

# Executable to run (must be logged in: `codex login`). Default: codex
CODEX_PLUGIN_COMMAND=codex

# Base args before the prompt (JSON array or space-separated). The defaults use
# a writable scratch sandbox, do not persist the prompt/session, and do not load
# unrelated user config. --skip-git-repo-check is required because the scratch
# directory is not a repo. Preserve equivalent isolation when overriding.
CODEX_PLUGIN_ARGS=["exec","--sandbox","workspace-write","--ephemeral","--ignore-user-config","--skip-git-repo-check"]

# Directory for per-request scratch subdirs. Default: OS temp dir.
CODEX_PLUGIN_TMPDIR=

# Advisory label reported as the result model. The subscription lane's real
# model is backend-decided (currently gpt-image-2) and NOT client-pinnable.
CODEX_PLUGIN_MODEL_LABEL=

# Authentication is not configurable: every request must pass
# `codex login status` with exactly "Logged in using ChatGPT" before generation.
